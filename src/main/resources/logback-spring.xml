<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProfile name="!prod">
        <!-- Console — human-readable for local dev -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    %d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] [%magenta(corrId=%X{correlationId})] %cyan(%logger{36}) - %msg%n
                </pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.migfora.sales" level="DEBUG"/>
<!--        <logger name="org.springframework.security" level="INFO"/>-->
<!--        <logger name="org.hibernate.SQL" level="DEBUG"/>-->
    </springProfile>

    <springProfile name="prod">
        <!-- JSON structured logs for production (Logstash / CloudWatch / Datadog) -->
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>requestPath</includeMdcKeyName>
                <includeMdcKeyName>httpMethod</includeMdcKeyName>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

        <logger name="com.migfora.sales" level="INFO"/>
    </springProfile>

</configuration>